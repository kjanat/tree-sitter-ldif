{
	"grammars": [
		{
			"name": "ldif",
			"scope": "source.ldif",
			"path": ".",
			"file-types": ["ldif"],
			"first-line-regex": "^(version:\\s*[0-9]+|dn:|DN:)",
			"injection-regex": "^ldif$",
			"highlights": "queries/highlights.scm",
			"injections": "queries/injections.scm",
			"tags": "queries/tags.scm",
			"locals": "queries/locals.scm"
		}
	],
	"metadata": {
		"version": "0.1.0",
		"license": "MIT",
		"links": {
			"repository": "https://github.com/kjanat/tree-sitter-ldif"
		}
	}
}
