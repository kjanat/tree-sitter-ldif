{
	"name": "tree-sitter-ldif",
	"version": "0.1.0",
	"description": "Tree-sitter grammar for LDIF (LDAP Data Interchange Format, RFC 2849)",
	"keywords": [
		"parser",
		"tree-sitter",
		"ldif",
		"ldap"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-ldif.git"
	},
	"license": "MIT",
	"type": "module",
	"main": "bindings/node",
	"files": [
		"grammar.js",
		"queries/*",
		"src/*",
		"bindings/node/*"
	],
	"scripts": {
		"build:wasm": "tree-sitter build --wasm",
		"fmt": "dprint fmt",
		"generate": "tree-sitter generate",
		"helix:sync": "mkdir -p ~/.config/helix/runtime/queries/ldif && cp queries/*.scm ~/.config/helix/runtime/queries/ldif/",
		"parse": "tree-sitter parse",
		"playground": "[[ -n tree-sitter-ldif.wasm ]] && bun build:wasm; tree-sitter playground --quiet --grammar-path .",
		"test": "tree-sitter test",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"dprint": "^0.53.0",
		"tree-sitter-cli": "^0.25.3",
		"typescript": "^5.9.3"
	},
	"packageManager": "bun@1.3.11"
}
